# Copy to `.env` (gitignored) and fill in. Consumed by dev-stack/compose.yaml's
# `tenants` service. NEVER commit real secrets — `.env` is gitignored.
#
# These are the values that vary per-developer / carry secrets. The non-secret
# config (DB URL, listen addrs, cert paths, ACCOUNT_BASE_URL=…:5173) is set
# directly in compose.yaml.

# ── Session cookie ───────────────────────────────────────────────────────────
# Symmetric key for the httpOnly session cookie jar. MUST be >= 64 bytes or the
# service refuses to boot. Generate your own — never commit a real key:
#   tr -dc 'A-Za-z0-9' </dev/urandom | head -c 80
COOKIE_KEY=

# ── Stripe (test mode) ───────────────────────────────────────────────────────
# 1. Stripe test secret key (Dashboard → Developers → API keys, "Test mode").
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# 2. Webhook signing secret. Get it by running, in another terminal:
#      stripe listen --forward-to localhost:5173/v1/billing/stripe/webhook
#    The CLI prints `whsec_…` — paste it here. (Keep the CLI running while testing.)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Also create a test Product with a recurring Price whose **metadata** carries
# `max_networks` and `max_daemons` (these become the entitlement). The SPA's
# price id lives in src/lib/plan.ts — keep them in sync.

# ── Google OAuth (optional — unset disables Google sign-in) ───────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (type: Web application). Authorized redirect URI MUST be exactly:
#   http://localhost:5173/v1/auth/oidc/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth (optional — unset disables GitHub sign-in) ───────────────────
# GitHub → Settings → Developer settings → OAuth Apps → New OAuth App.
# Authorization callback URL MUST be exactly:
#   http://localhost:5173/v1/auth/oidc/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email / verification codes (Resend) ──────────────────────────────────────
# Set RESEND_API_KEY to actually EMAIL the 6-digit codes. Leave it unset to use
# the dev no-op sender, which instead returns the code in the HTTP response (the
# Confirm screen surfaces it). For quick testing, Resend's onboarding sender only
# delivers to your own account email; verify a domain to send anywhere.
RESEND_API_KEY=
EMAIL_FROM=Wardnet <onboarding@resend.dev>
# Absolute URL of the brand logo (PNG) shown in HTML emails. Leave empty to fall
# back to the CSS wordmark. (SVG isn't used — many email clients won't render it.)
EMAIL_LOGO_URL=https://brand.wardnet.network/logos/logo-256.png
